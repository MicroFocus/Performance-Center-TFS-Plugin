<Application x:Class="PluginsUI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

        <!-- ── Brushes ─────────────────────────────────────────── -->
        <SolidColorBrush x:Key="AccentBrush"   Color="#0073E7"/>
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#005BB5"/>
        <SolidColorBrush x:Key="BorderBrush"   Color="#CCCCCC"/>
        <SolidColorBrush x:Key="FgBrush"       Color="#444444"/>
        <SolidColorBrush x:Key="SubtleFgBrush" Color="#888888"/>
        <SolidColorBrush x:Key="DangerBrush"   Color="#CC3300"/>

        <!-- ── NoChromeButton (tooltip / info icon trigger) ──── -->
        <Style x:Key="NoChromeButton" TargetType="Button">
            <Setter Property="Background"        Value="Transparent"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Setter Property="Focusable"         Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── MainButton ─────────────────────────────────────── -->
        <Style x:Key="MainButton" TargetType="Button">
            <Setter Property="Height"       Value="32"/>
            <Setter Property="MinWidth"     Value="88"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Foreground"   Value="#444444"/>
            <Setter Property="Margin"       Value="4,0,4,0"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="3" BorderThickness="1"
                                BorderBrush="#CCCCCC" Background="White" Padding="10,4">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"    Value="#0073E7"/>
                                <Setter TargetName="bd" Property="BorderBrush"   Value="#0073E7"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background"    Value="#005BB5"/>
                                <Setter TargetName="bd" Property="BorderBrush"   Value="#005BB5"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background"    Value="#F0F0F0"/>
                                <Setter TargetName="bd" Property="BorderBrush"   Value="#DDDDDD"/>
                                <Setter Property="Foreground" Value="#BBBBBB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── DangerButton (Stop) — standalone template so hover turns red ── -->
        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Height"     Value="32"/>
            <Setter Property="MinWidth"   Value="88"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Foreground" Value="#CC3300"/>
            <Setter Property="Margin"     Value="4,0,4,0"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="3" BorderThickness="1"
                                BorderBrush="#CCCCCC" Background="White" Padding="10,4">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"    Value="#CC3300"/>
                                <Setter TargetName="bd" Property="BorderBrush"   Value="#CC3300"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background"    Value="#AA2200"/>
                                <Setter TargetName="bd" Property="BorderBrush"   Value="#AA2200"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background"    Value="#F0F0F0"/>
                                <Setter TargetName="bd" Property="BorderBrush"   Value="#DDDDDD"/>
                                <Setter Property="Foreground" Value="#BBBBBB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── BrowseButton (compact inline) ─────────────────── -->
        <Style x:Key="BrowseButton" BasedOn="{StaticResource MainButton}" TargetType="Button">
            <Setter Property="Height"   Value="26"/>
            <Setter Property="MinWidth" Value="64"/>
            <Setter Property="Margin"   Value="4,0,0,0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- ── Global control styles ──────────────────────────── -->
        <Style TargetType="Label">
            <Setter Property="FontSize"           Value="13"/>
            <Setter Property="Foreground"         Value="#444444"/>
            <Setter Property="VerticalAlignment"  Value="Center"/>
            <Setter Property="Padding"            Value="0,0,6,0"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height"                  Value="28"/>
            <Setter Property="FontSize"                Value="13"/>
            <Setter Property="Padding"                 Value="4,0"/>
            <Setter Property="BorderBrush"             Value="#CCCCCC"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Height"                  Value="28"/>
            <Setter Property="FontSize"                Value="13"/>
            <Setter Property="Padding"                 Value="4,0"/>
            <Setter Property="BorderBrush"             Value="#CCCCCC"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="Foreground"        Value="#444444"/>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="VerticalAlignment"        Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="Foreground"               Value="#444444"/>
            <Setter Property="Margin"                   Value="0,3,0,3"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height"     Value="28"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Padding"    Value="4,0"/>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Margin"       Value="8,4,8,4"/>
            <Setter Property="Padding"      Value="10,8,10,10"/>
            <Setter Property="BorderBrush"  Value="#DDDDDD"/>
            <Setter Property="Foreground"   Value="#333333"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
        </Style>

        <Style x:Key="SectionHeaderText" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333333"/>
        </Style>

        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="FontSize"  Value="11"/>
            <Setter Property="Foreground" Value="#999999"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"    Value="4,0,0,0"/>
        </Style>

    </Application.Resources>
</Application>

